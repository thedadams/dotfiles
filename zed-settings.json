{
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "comment",
      },
    ],
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "ssh_connections": [
    {
      "host": "office.thedadams.com",
      "username": "thedadams",
      "port": 2200,
      "args": [],
      "projects": [
        {
          "paths": ["/Users/thedadams/.openclaw/./"],
        },
        {
          "paths": ["/Users/thedadams/code"],
        },
        {
          "paths": ["/Users/thedadams/code/gleam-mcp"],
        },
        {
          "paths": ["/Users/thedadams/code/leet"],
        },
      ],
    },
  ],
  "buffer_font_weight": 400.0,
  "colorize_brackets": true,
  "base_keymap": "JetBrains",
  "title_bar": {
    "show_branch_icon": true,
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "Git Commit": ["**/*.jjdescription"],
    "Git Attributes": ["{git,.git,.git/info}/attributes"],
    "Git Config": ["{git,.git/modules,.git/modules/*}/config"],
    "Git Ignore": ["{git,.git}/ignore", ".git/info/exclude"],
  },
  "lsp": {
    "wakatime": {
      "initialization_options": {
      },
    },
  },
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "profiles": {
      "local": {
        "name": "Local",
        "tools": {
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "move_path": true,
          "read_file": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "use_modifier_to_send": false,
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/nu",
        "args": ["--config", "~/.config.nu", "--env-config", "~/.env.nu"],
      },
    },
    "dock": "right",
    "cursor_shape": "bar",
  },
  "languages": {
    "Git Commit": {
      "wrap_guides": [72, 80],
      "preferred_line_length": 80,
    },
    "C": {
      "format_on_save": "on",
      "tab_size": 4,
    },
    "TypeScript": {
      "hard_tabs": true,
    },
  },
  "theme": "Flexoki Dark",
  "theme_overrides": {
    "Ayu Dark": {
      "syntax": {
        "constant.comment.todo": {
          "color": "#27618cff",
        },
        "string.comment.info": {
          "color": "#567627ff",
        },
        "keyword.comment.warn": {
          "color": "#92582bff",
        },
        "property.comment.error": {
          "color": "#83353bff",
        },
      },
    },
    "Flexoki Dark": {
      "syntax": {
        "constant.comment.todo": {
          "color": "#163b66ff",
        },
        "string.comment.info": {
          "color": "#3d4c07ff",
        },
        "keyword.comment.warn": {
          "color": "#71320dff",
        },
        "property.comment.error": {
          "color": "#6c201cff",
        },
      },
    },
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },
  "project_panel": {
    "dock": "left",
    "hide_root": false,
    "indent_size": 13.0,
    "entry_spacing": "standard",
    "auto_fold_dirs": false,
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 13,
  "ui_font_family": "Berkeley Mono",
  "buffer_font_family": "Berkeley Mono",
  "confirm_quit": true,
}
